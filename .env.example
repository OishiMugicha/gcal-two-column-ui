# FullCalendar Scheduler/Premium を GPLv3 OSS として使う場合のキーです。
VITE_FULLCALENDAR_LICENSE_KEY=GPL-My-Project-Is-Open-Source

# Google Cloud Console で作成した Web アプリケーション用 OAuth クライアントです。
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# refresh token を暗号化するための十分に長いランダム文字列です。
SESSION_SECRET=replace-with-a-long-random-secret

# Upstash Redis または Vercel KV の REST API 接続情報です。
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your-kv-rest-api-token
